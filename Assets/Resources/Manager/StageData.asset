  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c0ee3318b49956b4daa3fe9850f678c4, type: 3}
  m_Name: StageData
  m_EditorClassIdentifier: Assembly-CSharp::StageData
  cutSceneDatas:
  - type: 1
    stage: 1
    innerData:
    - name: "\uB0AF\uC120\uC774"
      dialog: "\uC545\uBABD\uC774 \uB2F9\uC2E0\uC744 \uCAD3\uC544\uC635\uB2C8\uB2E4"
    - name: "\uB0AF\uC120\uC774"
      dialog: "\uB2F9\uC2E0\uC740 \uC5BC\uB9C8\uB098 \uAFC8\uC744 \uC870\uC885\uD560
        \uC218 \uC788\uC744\uAE4C\uC694?"
    - name: "\uB0AF\uC120\uC774"
      dialog: "\uC720\uB2DB\uC744 \uD074\uB9AD\uD558\uBA74 \uD589\uB3D9\uBAA9\uB85D\uC774
        \uC5F4\uB9BD\uB2C8\uB2E4\n\uC624\uB978\uCABD \uD074\uB9AD\uC73C\uB85C \uB2EB\uC2B5\uB2C8\uB2E4"
  - type: 2
    stage: 1
    innerData:
    - name: 
      dialog: "\uB9C8\uB098\uAC00 \uC5C6\uC73C\uBA74 \uD134\uC774 \uC885\uB8CC\uB418\uACE0,
        \uD134\uC774 \uC2DC\uC791\uB418\uBA74 \uBAA8\uB450 \uD68C\uBCF5\uB429\uB2C8\uB2E4\n\uD558\uC9C0\uB9CC
        \uB2F9\uC2E0\uC740 \uB3C4\uB9DD\uAC08 \uC218 \uBC16\uC5D0 \uC5C6\uAD70\uC694"
    - name: 
      dialog: "\uD5C8\uC811\uD55C \uC870\uAC74\uC5D0 \uB9DE\uCD94\uC5B4 \uC2E4\uD589\uD558\uB294
        \uAD74\uB808\uC5D0 \uC788\uC2B5\uB2C8\uB2E4"
    - name: 
      dialog: "\uC800\uAE30 \uAFC8\uC18D\uC758 \uB2E4\uB978 \uAC1D\uCCB4\uAC00 \uBCF4\uC785\uB2C8\uB2E4\n\uADF8\uB4E4\uC5D0\uAC8C
        \uB2E4\uAC00\uAC00 \uB3C4\uC6C0\uC744 \uBC1B\uC73C\uC138\uC694"
  - type: 3
    stage: 1
    innerData:
    - name: 
      dialog: "\uC6B0\uD638\uC801\uC778 \uAFC8\uC18D \uAC1D\uCCB4\uB124\uC694\n\uB2F9\uC2E0\uC744
        \uB3C4\uC640\uC904 \uAC81\uB2C8\uB2E4"
    - name: 
      dialog: "\uC5EC\uB7EC \uC870\uAC74\uACFC \uC2E4\uD589\uC774, \uD558\uB098\uC758
        \uD589\uB3D9\uC73C\uB85C \uC774\uC5B4\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4\n\uC2E4\uD589\uC744
        \uD558\uBA74, \uCC98\uC74C\uBD80\uD130 \uC870\uAC74\uC744 \uB2E4\uC2DC \uD655\uC778\uD569\uB2C8\uB2E4"
    - name: 
      dialog: "\uC5EC\uB7EC \uD589\uB3D9\uC774 \uB3D9\uC2DC\uC5D0 \uC77C\uC5B4\uB098\uBA74,
        \uC8FC\uC778\uACF5\uACFC \uAC00\uAE4C\uC6B4\uCABD \uBD80\uD130 \uD589\uB3D9\uD569\uB2C8\uB2E4\n\uAC19\uC740
        \uAC70\uB9AC\uBA74 \uC624\uB978\uCABD \uC720\uB2DB\uC744 \uC6B0\uC120\uD569\uB2C8\uB2E4"
  - type: 1
    stage: 3
    innerData:
    - name: "\uC124\uBA85\uAFBC"
      dialog: "\uCEE4\uB2E4\uB780 \uC545\uBABD\uC774 \uC788\uB124\uC694\n\uC791\uC740
        \uC720\uB2DB\uC740 \uC774\uB3D9\uC2DC \uD070 \uC720\uB2DB\uACFC \uC790\uB9AC\uB97C
        \uBC14\uAFC0 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4"
    - name: "\uC124\uBA85\uAFBC"
      dialog: "\uB610\uD55C \uD134 \uC2DC\uC791\uC5D0 \uD589\uB3D9\uD558\uB294 \uC545\uBABD\uB3C4
        \uC788\uB124\uC694\n\uD134 \uC2DC\uC791\uC5D0\uB294 \uB9C8\uB098(Lucidity)\uB97C
        \uBAA8\uB450 \uC18C\uBAA8\uD558\uC9C0 \uC54A\uACE0, \uD55C\uBC88\uB9CC \uD589\uB3D9\uD569\uB2C8\uB2E4"
    - name: "\uC124\uBA85\uAFBC"
      dialog: "\uCC38\uACE0\uB85C \uB2F9\uC2E0\uC758 \uC2A4\uD0EF\uC774 \uC99D\uAC00\uD588\uC73C\uBA70
        \uCD94\uAC00 \uB2A5\uB825\uC774 \uC0DD\uACBC\uC2B5\uB2C8\uB2E4!\n\uD074\uB9AD\uD558\uC5EC
        \uD655\uC778\uD574 \uBCF4\uC138\uC694"
  - type: 1
    stage: 4
    innerData:
    - name: "\uC774\uC57C\uAE30\uAFBC"
      dialog: ...
    - name: "\uC774\uC57C\uAE30\uAFBC"
      dialog: "\uC774 \uB09C\uAD00\uC744 \uADF9\uBCF5 \uD560 \uC218 \uC788\uC744\uAE4C\uC694?"
  - type: 2
    stage: 4
    innerData:
    - name: 
      dialog: "\uC790\uAC01\uD558\uC138\uC694 \uB2F9\uC2E0\uC758 \uB2A5\uB825\uC744"
    - name: 
      dialog: "'Space bar' \uB97C \uB20C\uB7EC \uB8E8\uC2DC\uB4DC \uBAA8\uB4DC\uC5D0
        \uC9C4\uC785\uD558\uC138\uC694"
  - type: 3
    stage: 4
    innerData:
    - name: 
      dialog: "\uB450 \uC138\uB825\uC758 \uC815\uBCF4\uB97C \uD654\uBA74\uC5D0 \uB744\uC6B0\uC138\uC694"
    - name: 
      dialog: "\uC870\uAC74\uC744 \uAC01\uAC01 \uD074\uB9AD\uD558\uC5EC \uC11C\uB85C
        \uB2E4\uB978 \uC720\uB2DB\uC758 \uC870\uAC74\uC744 \uBCC0\uACBD\uD558\uC138\uC694"
  - type: 1
    stage: 2
    innerData:
    - name: 
      dialog: 
  portraitDatas: []
